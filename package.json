{
  "name": "whatsapp-integrated-crm",
  "private": true,
  "workspaces": [
    "apps/backend",
    "apps/frontend"
  ],
  "scripts": {
    "dev:backend": "npm --workspace apps/backend run dev",
    "dev:frontend": "npm --workspace apps/frontend run dev",
    "build": "npm --workspace apps/backend run build && npm --workspace apps/frontend run build",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  }
}
